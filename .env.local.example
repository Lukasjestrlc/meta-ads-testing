# Copy this file to .env.local and fill in the values.

# Meta Pixel ID — pixel only loads when set; blank is a safe no-op.
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Admin section (/admin) ───
# Password you'll type at /admin/login. Leaving these blank disables admin
# entirely (the public site keeps working).
ADMIN_PASSWORD=
# Random 32+ character string used to sign the session cookie. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ─── Vercel KV / Upstash Redis ───
# These get auto-injected when you connect Upstash Redis from the Vercel
# dashboard (Storage → Add Database → Upstash). Pull locally with:
#   vercel env pull .env.local
# Without these, the public site falls back to the seed list in
# src/data/creators.ts and admin saves will fail.
KV_REST_API_URL=
KV_REST_API_TOKEN=
