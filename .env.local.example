# Copy this file to .env.local and fill in the values.

# Meta Pixel ID — pixel only loads when set; blank is a safe no-op.
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Admin section (/admin) ───
# Password you'll type at /admin/login. Leaving these blank disables admin
# entirely (the public site keeps working).
ADMIN_PASSWORD=
# Random 32+ character string used to sign the session cookie. Generate with:
#   openssl rand -base64 32
ADMIN_SESSION_SECRET=

# ─── GitHub commit storage ───
# Admin saves commit data/creators.json to your repo via the GitHub API,
# which triggers a Vercel rebuild. Leave blank to disable saves (the
# public site still serves whatever is committed in data/creators.json,
# or the seed list if the file doesn't exist yet).
#
# 1. Generate a fine-grained Personal Access Token at
#    https://github.com/settings/tokens?type=beta
#    Repository access: only your fork/repo
#    Permissions → Contents: Read and write
GITHUB_TOKEN=
# 2. Format: "owner/name" (e.g. "Lukasjestrlc/meta-ads-testing")
GITHUB_REPO=
# 3. Branch to commit to. Defaults to "main" if blank.
GITHUB_BRANCH=
